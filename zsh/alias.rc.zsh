alias ll="ls -lA"
alias la="ls -A"
alias lf="ls -F"
alias cl="clear"
alias df="df -h"
alias du="du -h"
alias gco="gcc -Wall -o"
alias -g @g='| grep'
alias -g @f='| find'
alias -g @l='| less'
alias histf="history-all | less"
alias less="less -q"

